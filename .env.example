# Copy to .env and fill in for your environment.

# ─── Source mode ────────────────────────────────────────────────────────────
# The fetcher reads AdGuard Home's query log either:
#   (a) directly from disk, when running on the same machine as AdGuard Home, or
#   (b) over SSH, when AdGuard Home runs on a remote box (router, server).
#
# Mode is chosen by ROUTER_SSH_HOST:
#   - leave ROUTER_SSH_HOST blank for local mode
#   - set ROUTER_SSH_HOST (and ROUTER_SSH_USER) for SSH mode

# ─── SSH mode (only used when ROUTER_SSH_HOST is set) ───────────────────────
ROUTER_SSH_HOST=
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=

# ─── Source paths ───────────────────────────────────────────────────────────
# Path to AdGuard Home's query log on the source machine.
ADGUARD_QUERY_LOG=/opt/AdGuardHome/data/querylog.json

# Path to a dnsmasq-format DHCP leases file, used to resolve client IPs to
# hostnames. Optional — leave the default if you don't have one; client name
# resolution will silently no-op when the file is missing.
DHCP_LEASES_PATH=/var/lib/misc/dnsmasq.leases

# ─── Web server ─────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ─── Fetch tuning ───────────────────────────────────────────────────────────
# Bytes per chunk when streaming a large log file. Default: 1 MB.
FETCH_CHUNK_SIZE=1048576
